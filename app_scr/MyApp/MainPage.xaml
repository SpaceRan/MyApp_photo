<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyApp.MainPage"
             Title="癌症案例采集工具">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="Center">

            <!-- 标题 -->
            <Label Text="请选择工作模式" 
                   FontSize="24" 
                   HorizontalOptions="Center" 
                   Margin="0,0,0,20"/>

            <!-- 三个主模式按钮 -->
            <Button Text="模式 A：连续拍照" 
                    Clicked="OnModeA_Clicked"
                    HeightRequest="60"
                    FontSize="18"
                    BackgroundColor="#007ACC"
                    TextColor="White"/>

            <Button Text="模式 B：搜索确认后拍照" 
                    Clicked="OnModeB_Clicked"
                    HeightRequest="60"
                    FontSize="18"
                    BackgroundColor="#28A745"
                    TextColor="White"/>

            <Button Text="模式 C：任务指引拍照" 
                    Clicked="OnModeC_Clicked"
                    HeightRequest="60"
                    FontSize="18"
                    BackgroundColor="#DC3545"
                    TextColor="White"/>

            <!-- 分隔线 -->
            <BoxView HeightRequest="2" Color="Gray" Margin="0,20"/>

            <!-- 模式 B 专属区域：搜索框 -->
            <Frame x:Name="FrameModeB" IsVisible="False" BorderColor="#28A745" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="模式 B：输入姓名搜索" FontAttributes="Bold"/>
                    <Entry x:Name="EntrySearch" 
                           Placeholder="输入搜索内容..." 
                           TextColor="Black"
                           BackgroundColor="White"/>
                    <Button Text="执行搜索" Clicked="OnSearchExecute_Clicked" BackgroundColor="#28A745" TextColor="White"/>
                    <Label x:Name="LabelSearchResult" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- 模式 C 专属区域：任务文本框 -->
            <Frame x:Name="FrameModeC" IsVisible="False" BorderColor="#DC3545" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="模式 C：当前拍摄任务" FontAttributes="Bold"/>
                    <Frame BackgroundColor="#F8F9FA" Padding="15" CornerRadius="5">
                        <Label x:Name="LabelTaskText" 
                               Text="暂无任务信息" 
                               FontSize="20" 
                               LineBreakMode="WordWrap"
                               HorizontalOptions="Center"/>
                    </Frame>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">
                        <Button Text="📷 拍照" Clicked="OnTakePhoto_Clicked" BackgroundColor="#DC3545" TextColor="White"/>
                        <Button Text="下一个任务 ➡" Clicked="OnNextTask_Clicked" BackgroundColor="#6C757D" TextColor="White"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>