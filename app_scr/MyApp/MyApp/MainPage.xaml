<ScrollView>
    <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="Center">
        <Label Text="请选择工作模式" 
               FontSize="24" 
               HorizontalOptions="Center" 
               Margin="0,0,0,20"/>

        <Button Text="模式 A：连续拍照" 
                Clicked="OnModeA_Clicked"
                HeightRequest="60"
                FontSize="18"
                BackgroundColor="#007ACC"
                TextColor="White"/>

        <Button Text="模式 B：搜索确认后拍照" 
                Clicked="OnModeB_Clicked"
                HeightRequest="60"
                FontSize="18"
                BackgroundColor="#28A745"
                TextColor="White"/>

        <Button Text="模式 C：任务指引拍照" 
                Clicked="OnModeC_Clicked"
                HeightRequest="60"
                FontSize="18"
                BackgroundColor="#DC3545"
                TextColor="White"/>

        <BoxView HeightRequest="2" Color="Gray" Margin="0,20"/>
        
        <Label Text="📸 最新拍摄预览" 
               FontSize="16" 
               FontAttributes="Bold"
               HorizontalOptions="Center"/>
        
        <Image x:Name="ImgLastPhoto" 
               HeightRequest="250" 
               Aspect="AspectFit" 
               IsVisible="False"
               BackgroundColor="#F5F5F5"/>
        
        <Label x:Name="LabelPhotoCount" 
               Text="已保存：0 张" 
               FontSize="14" 
               TextColor="Gray"
               HorizontalOptions="Center"/>

        <BoxView HeightRequest="2" Color="Gray" Margin="0,20"/>
        
        <Border x:Name="FrameModeB" 
                IsVisible="False" 
                Stroke="#28A745" 
                StrokeThickness="2"
                StrokeShape="RoundRectangle 10">
            <VerticalStackLayout Spacing="10" Padding="15">
                <Label Text="模式 B：输入姓名搜索" FontAttributes="Bold"/>
                <Entry x:Name="EntrySearch" 
                       Placeholder="输入搜索内容..." 
                       TextColor="Black"
                       BackgroundColor="White"/>
                <Button Text="执行搜索" Clicked="OnSearchExecute_Clicked" BackgroundColor="#28A745" TextColor="White"/>
                <Label x:Name="LabelSearchResult" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

        <Border x:Name="FrameModeC" 
                IsVisible="False" 
                Stroke="#DC3545" 
                StrokeThickness="2"
                StrokeShape="RoundRectangle 10">

            <VerticalStackLayout Spacing="10" Padding="15">
                <Label Text="模式 C：当前拍摄任务" FontAttributes="Bold"/>
                <Border BackgroundColor="#F8F9FA" Padding="15" StrokeShape="RoundRectangle 5">
                    <Label x:Name="LabelTaskText" 
                           Text="暂无任务信息" 
                           FontSize="20" 
                           LineBreakMode="WordWrap"
                           HorizontalOptions="Center"/>
                </Border>
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">
                    <Button Text="📷 拍照" Clicked="OnTakePhoto_Clicked" BackgroundColor="#DC3545" TextColor="White"/>
                    <Button Text="下一个任务 ➡" Clicked="OnNextTask_Clicked" BackgroundColor="#6C757D" TextColor="White"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>
</ScrollView>